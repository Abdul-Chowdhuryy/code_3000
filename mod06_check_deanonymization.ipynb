   "source": [
    "import pandas as pd\n",
    "from mod06_deanonymize import load_data, link_records, deanonymization_rate"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "550c70a7",
   "metadata": {},
   "outputs": [],
   "source": [
    "anon_path = \"mod06_data/anonymized.csv\"\n",
    "aux_path = \"mod06_data/auxiliary.csv\""
   ]
  },
  {
   "cell_type": "markdown",
   "id": "3409ecb9",
   "metadata": {},
   "source": [
    "### Load and review the data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f76415fc",
   "metadata": {},
   "outputs": [],
   "source": [
    "anon, aux = load_data(anon_path, aux_path)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e0e149af",
   "metadata": {},
   "outputs": [],
   "source": [
    "anon.head(20)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "24556d9c",
   "metadata": {},
   "source": [
    "### Merge the datasets by age, gender, and zip3 and return the unique matches"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ecbaa9a4",
   "metadata": {},
   "outputs": [],
   "source": [
    "matches = link_records(anon, aux)\n",
    "matches.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "8e7ac45b",
   "metadata": {},
   "source": [
    "### Calculate the match rate"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1a156a39",
   "metadata": {},
   "outputs": [],
   "source": [
    "rate = deanonymization_rate(matches, anon)\n",
    "print(rate)"
   ]
  },
  {
   "cell_type": "markdown",
